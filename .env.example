# AFRICA FRONTIER MARKETS — PRODUCTION CONFIG

# Security (REQUIRED: SECRET_KEY >= 48 characters)
# AFM Configuration — local/dev reference.
# On Render, all of this is provisioned automatically by render.yaml;
# you only need to fill in the `sync: false` values in the dashboard
# during the Blueprint deploy flow (PSP keys, ALLOWED_ORIGINS, etc).

SECRET_KEY=change-me-to-64-char-random-hex-string-here-now-immediately
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (PostgreSQL 15+)
DATABASE_URL=postgresql+asyncpg://afm_user:strong_password@postgres:5432/africa_frontier_markets
# Database — accepts postgresql://, postgres://, or postgresql+asyncpg://
# (Render injects postgresql://; common/db_url.py normalizes it).
DATABASE_URL=postgresql+asyncpg://afm_user:strong_password@postgres:5432/afm
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30

# Redis (Rate limiting, sessions, events)
REDIS_URL=redis://redis:6379/0
REDIS_POOL_SIZE=50

# Payment Providers (LIVE KEYS — NEVER COMMIT)
KORA_API_KEY=pk_live_kora_...
KORA_SECRET_KEY=sk_live_kora_...
FINCRA_API_KEY=pk_live_fincra_...
FINCRA_SECRET_KEY=sk_live_fincra_...
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-...
FLUTTERWAVE_SECRET_KEY=FLWSECK-...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...

# FrontierPay Webhook Secrets (HMAC verification)
KORA_WEBHOOK_SECRET=whsec_kora_...
FINCRA_WEBHOOK_SECRET=whsec_fincra_...

# Platform
ENVIRONMENT=production
LOG_LEVEL=INFO
JSON_LOGS=true

# CORS (Strict in production)
ALLOWED_ORIGINS=https://app.africafrontiermarkets.com,https://admin.africafrontiermarkets.com

# Revenue Split
ADS_SHARE=0.35
CREATOR_SHARE=0.50
PLATFORM_SHARE=0.15

# Feature Flags
ENABLE_COPY_TRADING=true
ENABLE_SOCIAL_TRADING=true
MAX_COPY_ALLOCATION_PERCENT=100
# Redis
REDIS_URL=redis://redis:6379/0
REDIS_POOL_SIZE=50

# Payment Providers — REPLACE WITH REAL KEYS
KORA_API_KEY=pk_live_kora_REPLACE_ME
KORA_SECRET_KEY=sk_live_kora_REPLACE_ME
FINCRA_API_KEY=pk_live_fincra_REPLACE_ME
FINCRA_SECRET_KEY=sk_live_fincra_REPLACE_ME
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-REPLACE_ME
FLUTTERWAVE_SECRET_KEY=FLWSECK-REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME
STRIPE_SECRET_KEY=sk_live_REPLACE_ME

# Alpaca Trading — unused today (trading_engine/ is unimplemented)
ALPACA_API_KEY=PK_REPLACE_ME
ALPACA_SECRET_KEY=REPLACE_ME
ALPACA_PAPER=true

# Webhooks — REPLACE WITH REAL SECRETS
KORA_WEBHOOK_SECRET=whsec_kora_REPLACE_ME
FINCRA_WEBHOOK_SECRET=whsec_fincra_REPLACE_ME

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
JSON_LOGS=true

# AFM Revenue
AFM_COMMISSION_BPS=25
AFM_MIN_FEE_USD=0.50
AFM_MAX_FEE_USD=50.00

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000
