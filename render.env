# ============================================
# RENDER.COM ENVIRONMENT VARIABLES
# ============================================
# Copier ces valeurs dans le dashboard Render :
# Settings > Environment Variables

# Auto-généré par Render (ne pas modifier)
# SECRET_KEY=render-auto-generated-64-char-secret

# Base de données (auto-connectée par render.yaml)
# DATABASE_URL=postgresql+asyncpg://... (Render injecte)
# REDIS_URL=redis://... (Render injecte)

# PSP Keys — OBLIGATOIRES pour production
KORA_API_KEY=pk_live_votre_cle_kora
KORA_SECRET_KEY=sk_live_votre_cle_kora
KORA_WEBHOOK_SECRET=whsec_votre_secret_webhook_kora

FINCRA_API_KEY=pk_live_votre_cle_fincra
FINCRA_SECRET_KEY=sk_live_votre_cle_fincra
FINCRA_WEBHOOK_SECRET=whsec_votre_secret_webhook_fincra

FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-votre_cle_publique
FLUTTERWAVE_SECRET_KEY=FLWSECK-votre_cle_secrete

STRIPE_PUBLISHABLE_KEY=pk_live_votre_cle_stripe
STRIPE_SECRET_KEY=sk_live_votre_cle_stripe

# Configuration
ENVIRONMENT=production
LOG_LEVEL=INFO
JSON_LOGS=true

# CORS (ajouter le domaine Render une fois déployé)
ALLOWED_ORIGINS=https://africafrontiermarkets.com,https://app.africafrontiermarkets.com,https://afm-frontend.onrender.com

# Revenue Split
ADS_SHARE=0.35
CREATOR_SHARE=0.50
PLATFORM_SHARE=0.15

# Feature Flags
ENABLE_COPY_TRADING=true
ENABLE_SOCIAL_TRADING=true
MAX_COPY_ALLOCATION_PERCENT=100
